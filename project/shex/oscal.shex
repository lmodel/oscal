          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_ssp:diagrams @oscal_ssp:Diagram * ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ?
       ) ;
       rdf:type [ oscal_ssp:AuthorizationBoundary ] ?
    )
}

oscal_assessment_plan:AuthorizedPrivilege CLOSED {
    (  $oscal_assessment_plan:AuthorizedPrivilege_tes (  oscal_catalog:title @oscal_catalog:MarkupLineType ;
