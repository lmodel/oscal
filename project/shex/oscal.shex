oscal_assessment_plan:AtFrequency CLOSED {
    (  $oscal_assessment_plan:AtFrequency_tes (  oscal_assessment_plan:period @oscal_assessment_plan:PositiveIntegerType ;
          oscal_assessment_plan:unit [ <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#seconds>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#minutes>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#hours>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#days>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#months>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#years> ] ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ?
       ) ;
       rdf:type [ oscal_assessment_plan:AtFrequency ] ?
    )
}

oscal_assessment_results:Attestation CLOSED {
    (  $oscal_assessment_results:Attestation_tes (  &oscal_catalog:HasResponsibleParties_tes ;
          rdf:type [ oscal_catalog:HasResponsibleParties ] ? ;
          oscal_catalog:parts @oscal_assessment_plan:AssessmentPart + ;
          oscal_catalog:responsible_parties @oscal_catalog:ResponsibleParty *
       ) ;
       rdf:type [ oscal_assessment_results:Attestation ] ?
    )
}

