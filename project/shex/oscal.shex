# metamodel_version: 1.7.0
# version: 1.2.1
BASE <https://w3id.org/lmodel/oscal/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX linkml: <https://w3id.org/linkml/>
PREFIX oscal_catalog: <https://w3id.org/lmodel/oscal_catalog/>
PREFIX oscal_profile: <https://w3id.org/lmodel/oscal_profile/>
PREFIX oscal_ssp: <https://w3id.org/lmodel/oscal_ssp/>
PREFIX oscal_assessment_plan: <https://w3id.org/lmodel/oscal_assessment_plan/>
PREFIX oscal_assessment_results: <https://w3id.org/lmodel/oscal_assessment_results/>
PREFIX oscal_component: <https://w3id.org/lmodel/oscal_component/>
PREFIX oscal_mapping: <https://w3id.org/lmodel/oscal_mapping/>
PREFIX oscal_poam: <https://w3id.org/lmodel/oscal_poam/>


linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

oscal_catalog:UUIDType xsd:string

oscal_catalog:URIType IRI

oscal_catalog:URIReferenceType IRI

oscal_catalog:DateTimeWithTimezoneType xsd:dateTime

oscal_catalog:MarkupLineType xsd:string

oscal_catalog:MarkupMultilineType xsd:string

oscal_catalog:TokenType xsd:string

oscal_catalog:Base64Type xsd:base64Binary

oscal_catalog:EmailAddressType xsd:string

oscal_assessment_plan:NonNegativeIntegerType xsd:nonNegativeInteger

oscal_assessment_plan:PositiveIntegerType xsd:positiveInteger

oscal_catalog:Action CLOSED {
    (  $oscal_catalog:Action_tes (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          &oscal_catalog:HasResponsibleParties_tes ;
          rdf:type [ oscal_catalog:HasResponsibleParties ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:type [ <https://w3id.org/lmodel/oscal_catalog/ActionTypeEnum#approval>
             <https://w3id.org/lmodel/oscal_catalog/ActionTypeEnum#request-changes> ] ;
          oscal_catalog:date @oscal_catalog:DateTimeWithTimezoneType ? ;
          oscal_catalog:system @oscal_catalog:URIType ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:responsible_parties @oscal_catalog:ResponsibleParty *
       ) ;
       rdf:type [ oscal_catalog:Action ] ?
    )
}

oscal_assessment_plan:Activity CLOSED {
    (  $oscal_assessment_plan:Activity_tes (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          &oscal_catalog:HasResponsibleRoles_tes ;
          rdf:type [ oscal_catalog:HasResponsibleRoles ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ;
          oscal_assessment_plan:steps @oscal_assessment_plan:Step * ;
          oscal_assessment_plan:related_controls @oscal_assessment_plan:ReviewedControls ? ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:responsible_roles @oscal_catalog:ResponsibleRole *
       ) ;
       rdf:type [ oscal_assessment_plan:Activity ] ?
    )
}

oscal_profile:Addition CLOSED {
    (  $oscal_profile:Addition_tes (  oscal_profile:position [ <https://w3id.org/lmodel/oscal_profile/AdditionPositionEnum#before>
             <https://w3id.org/lmodel/oscal_profile/AdditionPositionEnum#after>
             <https://w3id.org/lmodel/oscal_profile/AdditionPositionEnum#starting>
             <https://w3id.org/lmodel/oscal_profile/AdditionPositionEnum#ending> ] ? ;
          oscal_profile:by_id @oscal_catalog:TokenType ? ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          oscal_catalog:params @oscal_catalog:Parameter * ;
          oscal_catalog:props @oscal_profile:ProfileAlterationProperty * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:parts @oscal_catalog:Part *
       ) ;
       rdf:type [ oscal_profile:Addition ] ?
    )
}

oscal_catalog:Address CLOSED {
    (  $oscal_catalog:Address_tes (  oscal_catalog:type @linkml:String ? ;
          oscal_catalog:addr_lines @linkml:String * ;
          oscal_catalog:city @linkml:String ? ;
          oscal_catalog:state @linkml:String ? ;
          oscal_catalog:postal_code @linkml:String ? ;
          oscal_catalog:country @linkml:String ?
       ) ;
       rdf:type [ oscal_catalog:Address ] ?
    )
}

oscal_profile:Alteration CLOSED {
    (  $oscal_profile:Alteration_tes (  oscal_catalog:control_id @oscal_catalog:TokenType ;
          oscal_profile:removes @oscal_profile:Removal * ;
          oscal_profile:adds @oscal_profile:Addition *
       ) ;
       rdf:type [ oscal_profile:Alteration ] ?
    )
}

oscal_assessment_plan:AssessmentAssets CLOSED {
    (  $oscal_assessment_plan:AssessmentAssets_tes (  oscal_assessment_plan:components @oscal_assessment_plan:SystemComponent * ;
          oscal_assessment_plan:assessment_platforms @oscal_assessment_plan:AssessmentPlatform +
       ) ;
       rdf:type [ oscal_assessment_plan:AssessmentAssets ] ?
    )
}

oscal_assessment_results:AssessmentLog CLOSED {
    (  $oscal_assessment_results:AssessmentLog_tes oscal_assessment_plan:entries @oscal_assessment_results:AssessmentLogEntry + ;
       rdf:type [ oscal_assessment_results:AssessmentLog ] ?
    )
}

oscal_assessment_results:AssessmentLogEntry CLOSED {
    (  $oscal_assessment_results:AssessmentLogEntry_tes (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          oscal_assessment_plan:start @oscal_catalog:DateTimeWithTimezoneType ;
          oscal_assessment_plan:end @oscal_catalog:DateTimeWithTimezoneType ? ;
          oscal_assessment_plan:logged_by @oscal_assessment_plan:LoggedBy * ;
          oscal_assessment_plan:related_tasks @oscal_assessment_plan:RelatedTask * ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ oscal_assessment_results:AssessmentLogEntry ] ?
    )
}

oscal_assessment_plan:AssessmentMethod CLOSED {
    (  $oscal_assessment_plan:AssessmentMethod_tes (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          oscal_assessment_plan:part @oscal_assessment_plan:AssessmentPart ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ oscal_assessment_plan:AssessmentMethod ] ?
    )
}

oscal_assessment_plan:AssessmentPart  (
    CLOSED {
       (  $oscal_assessment_plan:AssessmentPart_tes (  &oscal_catalog:HasPropsAndLinks_tes ;
             rdf:type [ oscal_catalog:HasPropsAndLinks ] ? ;
             oscal_catalog:uuid @oscal_catalog:UUIDType ? ;
             oscal_catalog:name @oscal_catalog:TokenType ;
             oscal_catalog:ns @oscal_catalog:URIType ? ;
             oscal_catalog:_class @oscal_catalog:TokenType ? ;
             oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
             oscal_catalog:prose @oscal_catalog:MarkupMultilineType ? ;
             oscal_catalog:parts @oscal_assessment_plan:AssessmentPart * ;
             oscal_catalog:props @oscal_catalog:Property * ;
             oscal_catalog:links @oscal_catalog:Link *
          ) ;
          rdf:type [ oscal_assessment_plan:AssessmentPart ] ?
       )
    } OR @oscal_assessment_plan:TermsAndConditionsPart
)

oscal_assessment_plan:AssessmentPlan CLOSED {
    (  $oscal_assessment_plan:AssessmentPlan_tes (  oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:metadata @oscal_catalog:Metadata ;
          oscal_assessment_plan:import_ssp @oscal_assessment_plan:ImportSSP ;
          oscal_assessment_plan:local_definitions @oscal_assessment_plan:LocalDefinitions ? ;
          oscal_assessment_plan:terms_and_conditions @oscal_assessment_plan:TermsAndConditions ? ;
          oscal_assessment_plan:assessment_subjects @oscal_assessment_plan:AssessmentSubject * ;
          oscal_assessment_plan:assessment_assets @oscal_assessment_plan:AssessmentAssets ? ;
          oscal_assessment_plan:reviewed_controls @oscal_assessment_plan:ReviewedControls ;
          oscal_assessment_plan:tasks @oscal_assessment_plan:Task * ;
          oscal_catalog:back_matter @oscal_catalog:BackMatter ?
       ) ;
       rdf:type [ oscal_assessment_plan:AssessmentPlan ] ?
    )
}

oscal_assessment_plan:AssessmentPlanDocument CLOSED {
    (  $oscal_assessment_plan:AssessmentPlanDocument_tes (  &oscal_catalog:OscalDocument_tes ;
          rdf:type [ oscal_catalog:OscalDocument ] ? ;
          oscal_assessment_plan:assessment_plan @oscal_assessment_plan:AssessmentPlan
       ) ;
       rdf:type [ oscal_assessment_plan:AssessmentPlanDocument ] ?
    )
}

