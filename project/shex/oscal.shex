}

oscal_catalog:Base64Resource CLOSED {
    (  $oscal_catalog:Base64Resource_tes (  oscal_catalog:media_type @linkml:String ? ;
          oscal_catalog:value @oscal_catalog:Base64Type ;
          oscal_catalog:filename @oscal_catalog:TokenType ?
       ) ;
       rdf:type [ oscal_catalog:Base64Resource ] ?
    )
}

oscal_ssp:ByComponent CLOSED {
    (  $oscal_ssp:ByComponent_tes (  oscal_assessment_plan:component_uuid @oscal_catalog:UUIDType ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ;
          oscal_catalog:props @oscal_ssp:SspControlOriginationProp * ;
          oscal_catalog:links @oscal_ssp:SspByComponentLink * ;
          oscal_catalog:set_parameters @oscal_assessment_plan:SetParameter * ;
          oscal_assessment_plan:implementation_status @oscal_assessment_plan:ImplementationStatus ? ;
          oscal_ssp:export @oscal_ssp:Export ? ;
          oscal_ssp:inherited @oscal_ssp:InheritedControlImplementation * ;
          oscal_ssp:satisfied @oscal_ssp:SatisfiedControlImplementation * ;
