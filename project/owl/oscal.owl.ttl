            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/role_id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/party_uuids> ],
