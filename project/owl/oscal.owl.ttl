<https://w3id.org/lmodel/oscal_catalog/sources> a owl:DatatypeProperty ;
    rdfs:label "sources" ;
    skos:definition "Source references or source-participation entries in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/statements> a owl:DatatypeProperty ;
