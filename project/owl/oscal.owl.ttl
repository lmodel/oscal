            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_component/control_implementations> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "A grouping of other components and/or capabilities." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_component> .

<https://w3id.org/lmodel/oscal_component/ComponentDefinition> a owl:Class ;
