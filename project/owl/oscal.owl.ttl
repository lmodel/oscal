        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:PartyExternalIdSchemeEnum xsd:anyURI ) ] xsd:anyURI ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ] ;
    skos:definition "An identifier for a person or organization using a designated scheme, e.g. an Open Researcher and Contributor ID (ORCID)." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/Resource> a owl:Class ;
