<https://w3id.org/lmodel/oscal_assessment_results/assessment_log> a owl:ObjectProperty ;
    rdfs:label "assessment-log" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_results/AssessmentLog> ;
