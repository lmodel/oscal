<https://w3id.org/lmodel/oscal_mapping/ConfidenceScore> a owl:Class ;
    rdfs:label "ConfidenceScore" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/category> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/category> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/percentage> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/percentage> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:ConfidenceCategoryEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/category> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/percentage> ] ;
    skos:definition "Confidence represented as a category and/or percentage value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/Coverage> a owl:Class ;
    rdfs:label "Coverage" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( oscal:CoverageGenerationMethodEnum xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/generation_method> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/target_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/target_coverage> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/target_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/generation_method> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/generation_method> ] ;
    skos:definition "A percentage representing target coverage by source mappings." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/GapSummary> a owl:Class ;
    rdfs:label "GapSummary" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/unmapped_controls> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/SelectControlById> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/unmapped_controls> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ] ;
    skos:definition "A summary of controls that were not mapped." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/MappingResourceReference> a owl:Class ;
    rdfs:label "MappingResourceReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:MappingResourceTypeEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "A reference to the source or target resource for a mapping." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_profile/insert_controls> a owl:ObjectProperty ;
