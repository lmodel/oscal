            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/base64> ] ;
    skos:definition "A resource associated with content in the containing document instance. A resource may be directly included in the document using base64 encoding or may point to one or more equivalent internet resources." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/ResourceLink> a owl:Class ;
