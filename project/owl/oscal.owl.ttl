    skos:definition "Mixin providing props, links, and remarks slots common to most OSCAL objects. Extends HasPropsAndLinks." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/links> a owl:ObjectProperty ;
    rdfs:label "links" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Link> ;
    skos:definition "A list of links." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/name> a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:range xsd:string ;
    skos:definition "A textual label that uniquely identifies an attribute or semantic type." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/props> a owl:ObjectProperty ;
    rdfs:label "props" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Property> ;
    skos:definition "A list of properties." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/title> a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:definition "A human-readable name or title." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/remarks> a owl:DatatypeProperty ;
    rdfs:label "remarks" ;
    rdfs:range xsd:string ;
    skos:definition "Additional commentary about the containing object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/description> a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:definition "A human-readable description." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/uuid> a owl:DatatypeProperty ;
    rdfs:label "uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented, globally unique identifier with a cross-instance scope." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

xsd:string a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^.+@.+$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ) ] .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/addresses> ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty <https://w3id.org/lmodel/oscal_catalog/location_uuids> ;
                owl:someValuesFrom xsd:string ] <https://w3id.org/lmodel/oscal_catalog/Party> ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/location_uuids> ;
            owl:someValuesFrom xsd:string ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty <https://w3id.org/lmodel/oscal_catalog/addresses> ;
                owl:someValuesFrom owl:Thing ] <https://w3id.org/lmodel/oscal_catalog/Party> ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/select> ;
            owl:someValuesFrom owl:Thing ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty <https://w3id.org/lmodel/oscal_catalog/values> ;
                owl:someValuesFrom xsd:string ] <https://w3id.org/lmodel/oscal_catalog/Parameter> ) .

[] rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/values> ;
            owl:someValuesFrom xsd:string ] ;
    owl:intersectionOf ( [ a owl:Restriction ;
                owl:onProperty <https://w3id.org/lmodel/oscal_catalog/select> ;
                owl:someValuesFrom owl:Thing ] <https://w3id.org/lmodel/oscal_catalog/Parameter> ) .


