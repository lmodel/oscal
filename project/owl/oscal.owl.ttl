<https://w3id.org/lmodel/oscal_catalog/locations> a owl:ObjectProperty ;
    rdfs:label "locations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Location> ;
    skos:definition "A physical point of presence, which may be associated with people, organizations, or other concepts within the current or linked OSCAL document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/matching> a owl:ObjectProperty ;
    rdfs:label "matching" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/ControlMatching> ;
