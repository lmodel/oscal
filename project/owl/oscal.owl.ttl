<https://w3id.org/lmodel/oscal_assessment_plan/related_observations> a owl:ObjectProperty ;
    rdfs:label "related-observations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RelatedObservation> ;
    skos:definition "Relates the containing object to a set of referenced observations." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/related_tasks> a owl:ObjectProperty ;
    rdfs:label "related-tasks" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RelatedTask> ;
    skos:definition "Identifies tasks for which the containing object is a consequence." ;
