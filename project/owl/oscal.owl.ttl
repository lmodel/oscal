<https://w3id.org/lmodel/oscal_assessment_plan/terms_and_conditions> a owl:ObjectProperty ;
    rdfs:label "terms-and-conditions" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditions> ;
