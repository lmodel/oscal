            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/metadata> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_implementation> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SystemCharacteristics> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_characteristics> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_implementation> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/metadata> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/control_implementation> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/control_implementation> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/import_profile> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/BackMatter> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/back_matter> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_characteristics> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/metadata> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SspControlImplementation> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/control_implementation> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/ImportProfile> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/import_profile> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SystemImplementation> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_implementation> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/back_matter> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/system_characteristics> ] ;
    skos:definition "A system security plan, such as those described in NIST SP 800-18." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/SystemStatus> a owl:Class ;
    rdfs:label "SystemStatus" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:SystemOperatingStatusEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/state> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/state> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/state> ] ;
    skos:definition "Describes the operational status of the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/categorizations> a owl:ObjectProperty ;
    rdfs:label "categorizations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/InformationTypeCategorization> ;
    skos:definition "A set of information type identifiers qualified by the given identification system used." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/information_type_ids> a owl:DatatypeProperty ;
    rdfs:label "information-type-ids" ;
    rdfs:range xsd:string ;
    skos:definition "An identifier qualified by the given identification system used, such as NIST SP 800-60." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/information_types> a owl:ObjectProperty ;
    rdfs:label "information-types" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/InformationType> ;
    skos:definition "Contains details about one information type that is stored, processed, or transmitted by the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/inherited> a owl:ObjectProperty ;
    rdfs:label "inherited" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/InheritedControlImplementation> ;
    skos:definition "Describes a control implementation inherited by a leveraging system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/leveraged_authorizations> a owl:ObjectProperty ;
    rdfs:label "leveraged-authorizations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/LeveragedAuthorization> ;
    skos:definition "A description of another authorized system from which this system inherits capabilities that satisfy security requirements." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/provided> a owl:ObjectProperty ;
    rdfs:label "provided" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ProvidedControlImplementation> ;
    skos:definition "Describes a capability which may be inherited by a leveraging system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/responsibilities> a owl:ObjectProperty ;
    rdfs:label "responsibilities" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ControlResponsibility> ;
    skos:definition "Describes a control implementation responsibility imposed on a leveraging system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/satisfied> a owl:ObjectProperty ;
    rdfs:label "satisfied" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/SatisfiedControlImplementation> ;
    skos:definition "Describes how this system satisfies a responsibility imposed by a leveraged system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/system_ids> a owl:ObjectProperty ;
    rdfs:label "system-ids" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SystemId> ;
    skos:definition "Unique identifiers for the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

