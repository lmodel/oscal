<https://w3id.org/lmodel/oscal_catalog/implemented_requirements> a owl:DatatypeProperty ;
    rdfs:label "implemented-requirements" ;
    skos:definition "Control implementation requirement entries in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/location_uuids> a owl:DatatypeProperty ;
