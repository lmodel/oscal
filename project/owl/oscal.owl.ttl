        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/Origin> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/origins> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/deadline> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/risk_log> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/threat_ids> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( oscal:RiskStatusEnum xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/RiskLog> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/risk_log> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/RelatedObservation> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/related_observations> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/origins> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/remediations> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/statement> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/statement> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/deadline> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/related_observations> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/Characterization> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/characterizations> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/MitigatingFactor> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/mitigating_factors> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/risk_log> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ThreatId> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/threat_ids> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/mitigating_factors> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/Response> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/remediations> ],
        <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> ;
    skos:definition "An identified risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/SubjectReference> a owl:Class ;
    rdfs:label "SubjectReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:SelectSubjectTypeEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/subject_uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/subject_uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/subject_uuid> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "A human-oriented identifier reference to a resource. Use type to indicate whether the identified resource is a component, inventory item, location, user, or something else." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/activity_uuid> a owl:DatatypeProperty ;
    rdfs:label "activity-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A UUID reference to an activity." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/actor_uuid> a owl:DatatypeProperty ;
    rdfs:label "actor-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to the tool or person based on the associated type." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/assessment_plan> a owl:ObjectProperty ;
    rdfs:label "assessment-plan" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlan> ;
    skos:definition "The root assessment plan object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/at_frequency> a owl:ObjectProperty ;
    rdfs:label "at-frequency" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AtFrequency> ;
    skos:definition "The task is intended to occur at the specified frequency." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/collected> a owl:DatatypeProperty ;
    rdfs:label "collected" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date/time stamp identifying when the finding information was collected." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/deadline> a owl:DatatypeProperty ;
    rdfs:label "deadline" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date/time by which the risk must be resolved." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/expires> a owl:DatatypeProperty ;
    rdfs:label "expires" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date/time identifying when the finding information is no longer considered valid." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/identified_subject> a owl:ObjectProperty ;
    rdfs:label "identified-subject" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/IdentifiedSubject> ;
    skos:definition "Used to detail assessment subjects that were identified by this task." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/identifier_type> a owl:DatatypeProperty ;
    rdfs:label "identifier-type" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:SystemIdentifierTypeEnum xsd:anyURI ) ] ;
    skos:definition "A human-readable label for a specific identifier scheme. Recommended values are in SystemIdentifierTypeEnum; other URI values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/implementation_statement_uuid> a owl:DatatypeProperty ;
    rdfs:label "implementation-statement-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to the implementation statement in the SSP to which this finding is related." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/implementation_uuid> a owl:DatatypeProperty ;
    rdfs:label "implementation-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented, globally unique identifier with cross-instance scope that can be used to reference this implementation statement elsewhere in this or other OSCAL instances." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/lifecycle> a owl:DatatypeProperty ;
    rdfs:label "lifecycle" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:ResponseLifecycleEnum xsd:string ) ] ;
    skos:definition "Identifies whether this is a recommendation or an actual plan. Recommended values are in ResponseLifecycleEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/objective_id> a owl:DatatypeProperty ;
    rdfs:label "objective-id" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to a control objective by its identifier." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/observation_uuid> a owl:DatatypeProperty ;
    rdfs:label "observation-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to an observation defined in the list of observations." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/on_date> a owl:ObjectProperty ;
    rdfs:label "on-date" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/OnDateCondition> ;
    skos:definition "The task is intended to occur on the specified date." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/origin> a owl:ObjectProperty ;
    rdfs:label "origin" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/Origin> ;
    skos:definition "The source of the finding." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/part> a owl:ObjectProperty ;
    rdfs:label "part" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPart> ;
    skos:definition "An assessment part." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/period> a owl:DatatypeProperty ;
    rdfs:label "period" ;
    rdfs:range xsd:positiveInteger ;
    skos:definition "The task must occur every period (in the given units)." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/reason> a owl:DatatypeProperty ;
    rdfs:label "reason" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:ObjectiveStatusReasonEnum xsd:string ) ] ;
    skos:definition "The reason the objective was given its status. Recommended values are in ObjectiveStatusReasonEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/related_controls> a owl:ObjectProperty ;
    rdfs:label "related-controls" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ReviewedControls> ;
    skos:definition "A reference to reviewed controls for this activity or step." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/response_uuid> a owl:DatatypeProperty ;
    rdfs:label "response-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to a unique risk response." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/risk_log> a owl:ObjectProperty ;
    rdfs:label "risk-log" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RiskLog> ;
    skos:definition "A log of all risk-related tasks taken." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/risk_uuid> a owl:DatatypeProperty ;
    rdfs:label "risk-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to a risk defined in the list of risks." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/statement> a owl:DatatypeProperty ;
    rdfs:label "statement" ;
    rdfs:range xsd:string ;
    skos:definition "An assessor's summary of the risk, in narrative form." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/status_change> a owl:DatatypeProperty ;
    rdfs:label "status-change" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:RiskStatusEnum xsd:string ) ] ;
    skos:definition "Identifies the risk change that prompted the log entry. Recommended values are in RiskStatusEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/subject_placeholder_uuid> a owl:DatatypeProperty ;
    rdfs:label "subject-placeholder-uuid" ;
