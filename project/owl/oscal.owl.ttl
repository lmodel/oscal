            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/related_responses> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "Identifies an individual risk response that occurred as part of managing an identified risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/RiskResponseReference> a owl:Class ;
    rdfs:label "RiskResponseReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/related_tasks> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/response_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/RelatedTask> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/related_tasks> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/response_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/response_uuid> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "Identifies an individual risk response that this log entry is for." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/Step> a owl:Class ;
    rdfs:label "Step" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ReviewedControls> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/reviewed_controls> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/reviewed_controls> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/reviewed_controls> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        <https://w3id.org/lmodel/oscal_catalog/HasResponsibleRoles>,
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "Identifies an individual step in a series of steps related to an activity, such as an assessment test or examination procedure." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/TaskDependency> a owl:Class ;
    rdfs:label "TaskDependency" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/task_uuid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/task_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/task_uuid> ] ;
    skos:definition "Used to indicate that a task is dependent on another task." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditions> a owl:Class ;
    rdfs:label "TermsAndConditions" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditionsPart> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ] ;
    skos:definition "Used to define various terms and conditions under which an assessment can be performed." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditionsPart> a owl:Class ;
    rdfs:label "TermsAndConditionsPart" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:TermsAndConditionsPartNameEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditionsPart> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPart> ;
    skos:definition "A terms-and-conditions scoped assessment part." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/ThreatId> a owl:Class ;
    rdfs:label "ThreatId" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/system> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/system> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/system> ] ;
    skos:definition "A pointer, by ID, to an externally-defined threat." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/UsesComponent> a owl:Class ;
    rdfs:label "UsesComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        <https://w3id.org/lmodel/oscal_catalog/HasResponsibleParties>,
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "The set of components that are used by the assessment platform." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/WithinDateRange> a owl:Class ;
    rdfs:label "WithinDateRange" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/start> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/end> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/end> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/start> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/start> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/end> ] ;
    skos:definition "The task is intended to occur within the specified date range." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/actors> a owl:ObjectProperty ;
    rdfs:label "actors" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/OriginActor> ;
    skos:definition "The actor that produces an observation, a finding, or a risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/assessment_platforms> a owl:ObjectProperty ;
    rdfs:label "assessment-platforms" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlatform> ;
    skos:definition "A collection of assessment platforms." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/assessment_subjects> a owl:ObjectProperty ;
    rdfs:label "assessment-subjects" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubject> ;
    skos:definition "Identifies system elements being assessed." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/associated_activities> a owl:ObjectProperty ;
    rdfs:label "associated-activities" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AssociatedActivity> ;
    skos:definition "Activities associated with this task." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/authorized_privileges> a owl:ObjectProperty ;
    rdfs:label "authorized-privileges" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/AuthorizedPrivilege> ;
    skos:definition "A collection of authorized privileges." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/characterizations> a owl:ObjectProperty ;
    rdfs:label "characterizations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/Characterization> ;
    skos:definition "Supporting information about the risk and how it relates to the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/control_objective_selections> a owl:ObjectProperty ;
    rdfs:label "control-objective-selections" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ControlObjectiveSelection> ;
    skos:definition "Identifies the control objectives of the assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/control_selections> a owl:ObjectProperty ;
    rdfs:label "control-selections" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ControlSelection> ;
    skos:definition "Identifies the controls being assessed." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/dependencies> a owl:ObjectProperty ;
    rdfs:label "dependencies" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/TaskDependency> ;
    skos:definition "Tasks that this task depends on." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/exclude_objectives> a owl:ObjectProperty ;
    rdfs:label "exclude-objectives" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SelectObjectiveById> ;
    skos:definition "Objectives to exclude from the assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/exclude_subjects> a owl:ObjectProperty ;
    rdfs:label "exclude-subjects" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SelectSubjectById> ;
    skos:definition "Assessment subjects to exclude." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/facets> a owl:ObjectProperty ;
    rdfs:label "facets" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/Facet> ;
    skos:definition "An individual characteristic that is part of a larger set produced by the same actor." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/functions_performed> a owl:DatatypeProperty ;
    rdfs:label "functions-performed" ;
    rdfs:range xsd:string ;
    skos:definition "Describes a function performed for a given authorized privilege." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/implemented_components> a owl:ObjectProperty ;
    rdfs:label "implemented-components" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ImplementedComponent> ;
    skos:definition "A collection of implemented components." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/include_objectives> a owl:ObjectProperty ;
    rdfs:label "include-objectives" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SelectObjectiveById> ;
    skos:definition "Objectives to include in the assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/include_subjects> a owl:ObjectProperty ;
    rdfs:label "include-subjects" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SelectSubjectById> ;
    skos:definition "Assessment subjects to include." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/methods> a owl:DatatypeProperty ;
    rdfs:label "methods" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:ObservationMethodEnum xsd:string ) ] ;
    skos:definition "Identifies how the observation was made. Recommended values are in ObservationMethodEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/mitigating_factors> a owl:ObjectProperty ;
    rdfs:label "mitigating-factors" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/MitigatingFactor> ;
    skos:definition "Describes existing mitigating factors that may affect the overall determination of the risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/port_ranges> a owl:ObjectProperty ;
    rdfs:label "port-ranges" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/PortRange> ;
    skos:definition "Where applicable, the transport layer protocol port range." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/related_responses> a owl:ObjectProperty ;
    rdfs:label "related-responses" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RiskResponseReference> ;
    skos:definition "Identifies an individual risk response that this log entry is for." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/relevant_evidence> a owl:ObjectProperty ;
    rdfs:label "relevant-evidence" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RelevantEvidence> ;
    skos:definition "Links the observation to relevant evidence." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/remediations> a owl:ObjectProperty ;
    rdfs:label "remediations" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/Response> ;
    skos:definition "Describes either recommended or actual responses to a risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/required_assets> a owl:ObjectProperty ;
    rdfs:label "required-assets" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/RequiredAsset> ;
    skos:definition "Identifies an asset required to achieve remediation." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/role_ids> a owl:DatatypeProperty ;
    rdfs:label "role-ids" ;
    rdfs:range xsd:string ;
    skos:definition "Role identifiers associated with the user." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/statement_ids> a owl:DatatypeProperty ;
    rdfs:label "statement-ids" ;
    rdfs:range xsd:string ;
    skos:definition "Statement IDs for control selection." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/steps> a owl:ObjectProperty ;
    rdfs:label "steps" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/Step> ;
    skos:definition "A collection of steps in an activity." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/threat_ids> a owl:ObjectProperty ;
    rdfs:label "threat-ids" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ThreatId> ;
    skos:definition "The referenced threat identifiers." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/types> a owl:DatatypeProperty ;
    rdfs:label "types" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:ObservationTypeEnum xsd:string ) ] ;
    skos:definition "Identifies the nature of the observation. Recommended values are in ObservationTypeEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/uses_components> a owl:ObjectProperty ;
    rdfs:label "uses-components" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/UsesComponent> ;
    skos:definition "The set of components used by the assessment platform." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_results/AssessmentLog> a owl:Class ;
    rdfs:label "AssessmentLog" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/entries> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_results/AssessmentLogEntry> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/entries> ] ;
    skos:definition "A log of all assessment-related actions taken." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_results> .

<https://w3id.org/lmodel/oscal_assessment_results/AssessmentResults> a owl:Class ;
    rdfs:label "AssessmentResults" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/back_matter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_results/ImportAssessmentPlan> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_results/import_ap> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_results/import_ap> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_results/AssessmentResultsLocalDefinitions> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/local_definitions> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/BackMatter> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/back_matter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_results/Result> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_results/results> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/metadata> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
