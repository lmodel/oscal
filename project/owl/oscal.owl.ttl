<https://w3id.org/lmodel/oscal_catalog/parties> a owl:ObjectProperty ;
    rdfs:label "parties" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Party> ;
    skos:definition "An organization or person, which may be associated with roles or other concepts within the current or linked OSCAL document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/resources> a owl:ObjectProperty ;
    rdfs:label "resources" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Resource> ;
    skos:definition "A resource associated with content in the containing document instance. A resource may be directly included in the document using base64 encoding or may point to one or more equivalent internet resources." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/revisions> a owl:ObjectProperty ;
    rdfs:label "revisions" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Revision> ;
    skos:definition "An entry in a sequential list of revisions to the containing document, expected to be in reverse chronological order (i.e. latest first)." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/rlinks> a owl:ObjectProperty ;
    rdfs:label "rlinks" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/ResourceLink> ;
    skos:definition "A URL-based pointer to an external resource with an optional hash for verification and change detection." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/roles> a owl:ObjectProperty ;
    rdfs:label "roles" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Role> ;
    skos:definition "Defines a function, which might be assigned to a party in a specific situation." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/tests> a owl:ObjectProperty ;
    rdfs:label "tests" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/ConstraintTest> ;
    skos:definition "A test expression which is expected to be evaluated by a tool." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/urls> a owl:DatatypeProperty ;
    rdfs:label "urls" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The uniform resource locator (URL) for a web site or other resource associated with the location." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/with_ids> a owl:DatatypeProperty ;
