<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentAssets> a owl:Class ;
    rdfs:label "AssessmentAssets" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlatform> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/assessment_platforms> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/components> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/SystemComponent> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/components> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/assessment_platforms> ] ;
    skos:definition "Identifies the assets used to perform this assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonLink> a owl:Class ;
    rdfs:label "ImplementationCommonLink" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/rel> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/rel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( oscal:ImplementationLinkRelEnum xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/rel> ],
        <https://w3id.org/lmodel/oscal_catalog/Link> ;
    skos:definition "Implementation-common scoped OSCAL link." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonProperty> a owl:Class ;
    rdfs:label "ImplementationCommonProperty" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:ImplementationPropNameEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:unionOf ( oscal:ImplementationYesNoEnum oscal:ImplementationAssetTypeEnum oscal:ImplementationPointEnum oscal:ImplementationIpAddressClassEnum oscal:ImplementationDirectionEnum oscal:UserTypeEnum oscal:UserPrivilegeLevelEnum xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        <https://w3id.org/lmodel/oscal_catalog/Property> ;
    skos:definition "Implementation-common scoped OSCAL property." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/RelatedObservation> a owl:Class ;
    rdfs:label "RelatedObservation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
