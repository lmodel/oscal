            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/IncludeAll> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_all> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_all> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/SelectSubjectById> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/include_subjects> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:AssessmentSubjectTypeEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/exclude_subjects> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/SelectSubjectById> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/exclude_subjects> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/include_subjects> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "Identifies system elements being assessed, such as components, inventory items, and locations." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/ReviewedControls> a owl:Class ;
    rdfs:label "ReviewedControls" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ControlObjectiveSelection> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/control_objective_selections> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ControlSelection> ;
