            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> ;
    skos:definition "A structured object representing a requirement or guideline, which when implemented will reduce an aspect of risk related to an information system and its information." ;
