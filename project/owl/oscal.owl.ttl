        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/control_selections> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/control_objective_selections> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "Identifies the controls being assessed and their control objectives." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/SystemComponent> a owl:Class ;
    rdfs:label "SystemComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonLink> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/protocols> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonProperty> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStatus> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/purpose> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:ComponentTypeEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/Protocol> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/protocols> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationResponsibleRole> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/purpose> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/purpose> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        <https://w3id.org/lmodel/oscal_catalog/HasResponsibleRoles>,
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "A defined component that can be part of an implemented system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/implementation_status> a owl:ObjectProperty ;
    rdfs:label "implementation-status" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationStatus> ;
    skos:definition "Identifies the implementation status of the control." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/import_ssp> a owl:ObjectProperty ;
    rdfs:label "import-ssp" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/ImportSSP> ;
    skos:definition "Used to import information about the system from an SSP." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/party_uuid> a owl:DatatypeProperty ;
    rdfs:label "party-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to the party who is making the log entry." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/purpose> a owl:DatatypeProperty ;
    rdfs:label "purpose" ;
