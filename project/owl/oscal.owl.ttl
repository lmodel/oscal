<https://w3id.org/lmodel/oscal_catalog/addr_lines> a owl:DatatypeProperty ;
    rdfs:label "addr-lines" ;
    rdfs:range xsd:string ;
    skos:definition "A single line of an address." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/choice> a owl:DatatypeProperty ;
    rdfs:label "choice" ;
    rdfs:range xsd:string ;
    skos:definition "A value selection among several such options." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/external_ids> a owl:ObjectProperty ;
    rdfs:label "external-ids" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/PartyExternalId> ;
    skos:definition "An identifier for a person or organization using a designated scheme, e.g. an Open Researcher and Contributor ID (ORCID)." ;
