    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_results> .

<https://w3id.org/lmodel/oscal_assessment_results/assessment_results> a owl:ObjectProperty ;
    rdfs:label "assessment-results" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_results/AssessmentResults> ;
    skos:definition "The root assessment results object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_results> .

<https://w3id.org/lmodel/oscal_assessment_results/import_ap> a owl:ObjectProperty ;
    rdfs:label "import-ap" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_results/ImportAssessmentPlan> ;
    skos:definition "Used to import information about the governing assessment plan." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_results> .

<https://w3id.org/lmodel/oscal_catalog/DocumentId> a owl:Class ;
    rdfs:label "DocumentId" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/identifier> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:DocumentIdSchemeEnum xsd:anyURI ) ] xsd:anyURI ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/identifier> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/identifier> ] ;
    skos:definition "A document identifier qualified by an identifier scheme." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/Group> a owl:Class ;
    rdfs:label "Group" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/params> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Part> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/controls> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Group> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/groups> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Parameter> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/params> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/groups> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Control> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/controls> ],
        <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> ;
    skos:definition "A group of controls, or of groups of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/ParameterConstraint> a owl:Class ;
    rdfs:label "ParameterConstraint" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/tests> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/ConstraintTest> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/tests> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ] ;
    skos:definition "A formal or informal expression of a constraint or test." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/ParameterGuideline> a owl:Class ;
    rdfs:label "ParameterGuideline" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ] ;
    skos:definition "A prose statement that provides a recommendation for the use of a parameter." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/ParameterSelection> a owl:Class ;
    rdfs:label "ParameterSelection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/choice> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/how_many> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:ParameterCardinalityEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/how_many> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/choice> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/how_many> ] ;
    skos:definition "Presenting a choice among alternatives." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/TelephoneNumber> a owl:Class ;
    rdfs:label "TelephoneNumber" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/number> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/number> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/number> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:PhoneTypeEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ] ;
    skos:definition "A telephone service number as defined by ITU-T E.164." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/address> a owl:ObjectProperty ;
    rdfs:label "address" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Address> ;
    skos:definition "A postal address for the location." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/algorithm> a owl:DatatypeProperty ;
    rdfs:label "algorithm" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:HashAlgorithmEnum xsd:string ) ] ;
    skos:definition "The digest method by which a hash is derived. Recommended values are in HashAlgorithmEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/base64> a owl:ObjectProperty ;
    rdfs:label "base64" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Base64Resource> ;
    skos:definition "A resource encoded using the Base64 alphabet defined by RFC 2045." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/catalog> a owl:ObjectProperty ;
    rdfs:label "catalog" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Catalog> ;
    skos:definition "Root catalog document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/citation> a owl:ObjectProperty ;
    rdfs:label "citation" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Citation> ;
    skos:definition "An optional citation consisting of end note text using structured markup." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/city> a owl:DatatypeProperty ;
    rdfs:label "city" ;
    rdfs:range xsd:string ;
    skos:definition "City, town or geographical region for the mailing address." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/country> a owl:DatatypeProperty ;
    rdfs:label "country" ;
    rdfs:range xsd:string ;
    skos:definition "The ISO 3166-1 alpha-2 country code for the mailing address." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/expression> a owl:DatatypeProperty ;
    rdfs:label "expression" ;
    rdfs:range xsd:string ;
    skos:definition "A formal (executable) expression of a constraint." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/filename> a owl:DatatypeProperty ;
    rdfs:label "filename" ;
    rdfs:range xsd:string ;
    skos:definition "Name of the file before it was encoded as Base64 to be embedded in a resource." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/group> a owl:DatatypeProperty ;
    rdfs:label "group" ;
    rdfs:range xsd:string ;
    skos:definition "An identifier for relating distinct sets of properties." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/how_many> a owl:ObjectProperty ;
    rdfs:label "how-many" ;
    rdfs:range oscal:ParameterCardinalityEnum ;
    skos:altLabel "how_many" ;
    skos:definition "Describes the number of selections that must occur. Without this setting, only one value should be assumed to be permitted." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/identifier> a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:range xsd:string ;
    skos:definition "A document identifier value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/number> a owl:DatatypeProperty ;
    rdfs:label "number" ;
    rdfs:range xsd:string ;
    skos:definition "A telephone number value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/pattern> a owl:DatatypeProperty ;
    rdfs:label "pattern" ;
    rdfs:range xsd:string ;
    skos:definition "A glob expression matching the IDs of one or more controls to be selected." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/postal_code> a owl:DatatypeProperty ;
    rdfs:label "postal-code" ;
    rdfs:range xsd:string ;
    skos:definition "Postal or ZIP code for mailing address." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/resource_fragment> a owl:DatatypeProperty ;
    rdfs:label "resource-fragment" ;
    rdfs:range xsd:string ;
    skos:definition "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/with_child_controls> a owl:ObjectProperty ;
    rdfs:label "with-child-controls" ;
    rdfs:range oscal:WithChildControlsEnum ;
    skos:definition "When a control is included, whether its child (dependent) controls are also included." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_component/ControlImplementationSet> a owl:Class ;
    rdfs:label "ControlImplementationSet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/SetParameter> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/set_parameters> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_component/source> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_component/source> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_component/source> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/set_parameters> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_component/ImplementedRequirement> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/implemented_requirements> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/implemented_requirements> ],
        <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> ;
    skos:definition "Defines how the component or capability supports a set of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_component> .

<https://w3id.org/lmodel/oscal_component/component_definition> a owl:ObjectProperty ;
    rdfs:label "component-definition" ;
    rdfs:range <https://w3id.org/lmodel/oscal_component/ComponentDefinition> ;
    skos:definition "The root component-definition object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_component> .

<https://w3id.org/lmodel/oscal_component/source> a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Reference to an external catalog or profile resource." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_component> .

<https://w3id.org/lmodel/oscal_mapping/MappingItem> a owl:Class ;
    rdfs:label "MappingItem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/id_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:MappingSubjectTypeEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/id_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_mapping/id_ref> ],
        <https://w3id.org/lmodel/oscal_catalog/OscalCommon> ;
    skos:definition "A source or target item participating in a mapping entry." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/generation_method> a owl:DatatypeProperty ;
    rdfs:label "generation-method" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:CoverageGenerationMethodEnum xsd:string ) ] ;
    skos:definition "Method used to determine the coverage value. Recommended values are in CoverageGenerationMethodEnum; other values are permitted." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/id_ref> a owl:DatatypeProperty ;
    rdfs:label "id-ref" ;
    rdfs:range xsd:string ;
    skos:definition "Identifier reference of a source/target subject." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/mapping_collection> a owl:ObjectProperty ;
    rdfs:label "mapping-collection" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/MappingCollection> ;
    skos:definition "The root mapping collection object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/percentage> a owl:DatatypeProperty ;
    rdfs:label "percentage" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
    skos:definition "A decimal percentage value in the range 0 to 1." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/predicate> a owl:ObjectProperty ;
    rdfs:label "predicate" ;
    rdfs:range oscal:QualifierPredicateEnum ;
    skos:definition "Predicate describing qualifier semantics." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/provenance> a owl:ObjectProperty ;
    rdfs:label "provenance" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/MappingProvenance> ;
    skos:definition "Global provenance and mapping method metadata." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/relationship> a owl:DatatypeProperty ;
    rdfs:label "relationship" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:unionOf ( oscal:RelationshipEnum xsd:string ) ] ;
    skos:definition "Relationship type for a mapping entry. OSCAL namespace values are defined by RelationshipEnum." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/source_gap_summary> a owl:ObjectProperty ;
    rdfs:label "source-gap-summary" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/GapSummary> ;
    skos:definition "Summary of unmapped source controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/source_resource> a owl:ObjectProperty ;
    rdfs:label "source-resource" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/MappingResourceReference> ;
    skos:definition "Reference to the mapping source resource." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/subject> a owl:ObjectProperty ;
    rdfs:label "subject" ;
    rdfs:range oscal:QualifierSubjectEnum ;
    skos:definition "Subject to which the qualifier applies." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/target_coverage> a owl:DatatypeProperty ;
    rdfs:label "target-coverage" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 1 ] ) ] ) ] ;
    skos:definition "Percentage coverage of targets by sources." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/target_gap_summary> a owl:ObjectProperty ;
    rdfs:label "target-gap-summary" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/GapSummary> ;
    skos:definition "Summary of unmapped target controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/target_resource> a owl:ObjectProperty ;
    rdfs:label "target-resource" ;
    rdfs:range <https://w3id.org/lmodel/oscal_mapping/MappingResourceReference> ;
    skos:definition "Reference to the mapping target resource." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_poam/finding_uuid> a owl:DatatypeProperty ;
    rdfs:label "finding-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A UUID reference to a finding." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_poam> .

<https://w3id.org/lmodel/oscal_poam/plan_of_action_and_milestones> a owl:ObjectProperty ;
    rdfs:label "plan-of-action-and-milestones" ;
    rdfs:range <https://w3id.org/lmodel/oscal_poam/PlanOfActionAndMilestones> ;
    skos:definition "The root plan of action and milestones object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_poam> .

<https://w3id.org/lmodel/oscal_poam/system_id> a owl:ObjectProperty ;
    rdfs:label "system-id" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SystemId> ;
    skos:definition "A human-oriented, globally unique identifier for a system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_poam> .

<https://w3id.org/lmodel/oscal_profile/InsertControls> a owl:Class ;
    rdfs:label "InsertControls" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/SelectControlById> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_controls> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_profile/order> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/IncludeAll> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_all> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/SelectControlById> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/exclude_controls> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/exclude_controls> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_controls> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_profile/order> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_all> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/include_all> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:InsertOrderEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_profile/order> ] ;
    skos:definition "Specifies which controls to use in the containing context (as part of a group or custom merge structure)." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/as_is> a owl:DatatypeProperty ;
    rdfs:label "as-is" ;
    rdfs:range xsd:boolean ;
    skos:definition "When true, retain the original grouping structure as defined in the import source." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/by_class> a owl:DatatypeProperty ;
    rdfs:label "by-class" ;
    rdfs:range xsd:string ;
    skos:definition "Identify items to remove by their class label." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/by_item_name> a owl:ObjectProperty ;
    rdfs:label "by-item-name" ;
    rdfs:range oscal:ByItemNameEnum ;
    skos:definition "Identify items to remove by the item's information object type name." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/by_name> a owl:DatatypeProperty ;
    rdfs:label "by-name" ;
    rdfs:range xsd:string ;
    skos:definition "Identify items to remove by their assigned name." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/by_ns> a owl:DatatypeProperty ;
    rdfs:label "by-ns" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Identify items to remove by the item's namespace." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/combine> a owl:ObjectProperty ;
    rdfs:label "combine" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/CombinationRule> ;
    skos:definition "Defines how to resolve duplicate instances of the same control." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/custom> a owl:ObjectProperty ;
    rdfs:label "custom" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/MergeCustom> ;
    skos:definition "Provides an alternate grouping structure that selected controls will be placed in." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/flat> a owl:ObjectProperty ;
    rdfs:label "flat" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/MergeFlat> ;
    skos:definition "Directs that controls appear without any grouping structure." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/merge> a owl:ObjectProperty ;
    rdfs:label "merge" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/ProfileMerge> ;
    skos:definition "Structuring directives for how controls are organized after profile resolution." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/modify> a owl:ObjectProperty ;
    rdfs:label "modify" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/ProfileModify> ;
    skos:definition "Set parameters or amend controls in resolution." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/order> a owl:ObjectProperty ;
    rdfs:label "order" ;
    rdfs:range oscal:InsertOrderEnum ;
    skos:definition "A designation of how a selection of controls is to be ordered." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/position> a owl:ObjectProperty ;
    rdfs:label "position" ;
    rdfs:range oscal:AdditionPositionEnum ;
    skos:definition "Where to add new content relative to the targeted element." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_profile/profile> a owl:ObjectProperty ;
    rdfs:label "profile" ;
    rdfs:range <https://w3id.org/lmodel/oscal_profile/Profile> ;
    skos:definition "The root profile object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_ssp/ByComponent> a owl:Class ;
    rdfs:label "ByComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/implementation_status> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/set_parameters> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/inherited> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SspByComponentLink> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/Export> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/export> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/export> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/SetParameter> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/set_parameters> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SspByComponentResponsibleRole> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/InheritedControlImplementation> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/inherited> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationStatus> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/implementation_status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/uuid> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/implementation_status> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/export> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SatisfiedControlImplementation> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/satisfied> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_assessment_plan/component_uuid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_ssp/SspControlOriginationProp> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/satisfied> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    skos:definition "Defines how the referenced component implements a set of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/SspControlOriginationProp> a owl:Class ;
    rdfs:label "SspControlOriginationProp" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:ControlOriginationValueEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal:ControlOriginationPropNameEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        <https://w3id.org/lmodel/oscal_catalog/Property> ;
    skos:definition "SSP-scoped property used in implemented requirement and by-component contexts." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/adjustment_justification> a owl:DatatypeProperty ;
    rdfs:label "adjustment-justification" ;
    rdfs:range xsd:string ;
    skos:definition "If the selected security level is different from the base security level, this contains the justification for the change." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/authorization_boundary> a owl:ObjectProperty ;
    rdfs:label "authorization-boundary" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/AuthorizationBoundary> ;
    skos:definition "A description of this system's authorization boundary, optionally supplemented with diagrams that illustrate the authorization boundary." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/availability_impact> a owl:ObjectProperty ;
    rdfs:label "availability-impact" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
    skos:definition "The expected level of impact resulting from the disruption of access to or use of the described information or the information system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/base> a owl:DatatypeProperty ;
    rdfs:label "base" ;
    rdfs:range xsd:string ;
    skos:definition "The prescribed base (Confidentiality, Integrity, or Availability) security impact level." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/caption> a owl:DatatypeProperty ;
    rdfs:label "caption" ;
    rdfs:range xsd:string ;
    skos:definition "A brief caption to annotate the diagram." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/confidentiality_impact> a owl:ObjectProperty ;
    rdfs:label "confidentiality-impact" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
    skos:definition "The expected level of impact resulting from the unauthorized disclosure of the described information." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/control_implementation> a owl:ObjectProperty ;
    rdfs:label "control-implementation" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/SspControlImplementation> ;
    skos:definition "Describes how the system satisfies a set of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/data_flow> a owl:ObjectProperty ;
    rdfs:label "data-flow" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/DataFlow> ;
    skos:definition "A description of the logical flow of information within the system and across its boundaries, optionally supplemented with diagrams." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/export> a owl:ObjectProperty ;
    rdfs:label "export" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/Export> ;
    skos:definition "Defines a set of control implementations that are provided as reference implementations for use by organizations implementing the leveraged system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/import_profile> a owl:ObjectProperty ;
    rdfs:label "import-profile" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ImportProfile> ;
    skos:definition "Used to import the OSCAL profile representing the system's control baseline." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/integrity_impact> a owl:ObjectProperty ;
    rdfs:label "integrity-impact" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
    skos:definition "The expected level of impact resulting from the unauthorized modification of the described information." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/network_architecture> a owl:ObjectProperty ;
    rdfs:label "network-architecture" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/NetworkArchitecture> ;
    skos:definition "A description of the system's network architecture, optionally supplemented with diagrams that illustrate the network architecture." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/responsibility_uuid> a owl:DatatypeProperty ;
    rdfs:label "responsibility-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "Machine-oriented identifier reference to a control implementation responsibility imposed by a leveraged system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/security_impact_level> a owl:ObjectProperty ;
    rdfs:label "security-impact-level" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/SecurityImpactLevel> ;
    skos:definition "The overall level of expected impact resulting from unauthorized disclosure, modification, or loss of access to information." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/security_objective_availability> a owl:DatatypeProperty ;
    rdfs:label "security-objective-availability" ;
    rdfs:range xsd:string ;
    skos:definition "A target-level of availability for the system, based on the sensitivity of information within the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/security_objective_confidentiality> a owl:DatatypeProperty ;
    rdfs:label "security-objective-confidentiality" ;
    rdfs:range xsd:string ;
    skos:definition "A target-level of confidentiality for the system, based on the sensitivity of information within the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/security_objective_integrity> a owl:DatatypeProperty ;
    rdfs:label "security-objective-integrity" ;
    rdfs:range xsd:string ;
    skos:definition "A target-level of integrity for the system, based on the sensitivity of information within the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/security_sensitivity_level> a owl:DatatypeProperty ;
    rdfs:label "security-sensitivity-level" ;
    rdfs:range xsd:string ;
    skos:definition "The overall information system sensitivity categorization, such as defined by FIPS-199." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/selected> a owl:DatatypeProperty ;
    rdfs:label "selected" ;
    rdfs:range xsd:string ;
    skos:definition "The selected (Confidentiality, Integrity, or Availability) security impact level." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/state> a owl:ObjectProperty ;
    rdfs:label "state" ;
    skos:definition "The current operating status of the system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/system> a owl:DatatypeProperty ;
    rdfs:label "system" ;
    skos:definition "Specifies the information type identification system used. Recommended values are in InformationTypeCategorizationSystemEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/system_characteristics> a owl:ObjectProperty ;
    rdfs:label "system-characteristics" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/SystemCharacteristics> ;
    skos:definition "Contains the characteristics of the system, such as its name, purpose, and security impact level." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_ssp> .

<https://w3id.org/lmodel/oscal_ssp/system_implementation> a owl:ObjectProperty ;
    rdfs:label "system-implementation" ;
    rdfs:range <https://w3id.org/lmodel/oscal_ssp/SystemImplementation> ;
