<https://w3id.org/lmodel/oscal_assessment_plan/subject_uuid> a owl:DatatypeProperty ;
    rdfs:label "subject-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A UUID reference to the identified subject." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/users> a owl:ObjectProperty ;
    rdfs:label "users" ;
    rdfs:range <https://w3id.org/lmodel/oscal_assessment_plan/SystemUser> ;
    skos:definition "A collection of system users." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_catalog/IncludeAll> a owl:Class ;
    rdfs:label "IncludeAll" ;
    skos:definition "Include all controls from the imported catalog or profile resources." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/Part> a owl:Class ;
    rdfs:label "Part" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/PartProperty> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/prose> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Part> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/name> ],
        <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> ;
    skos:definition "An annotated, markup-based textual element of a control's or catalog group's definition, or a child of another part." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/SelectControlById> a owl:Class ;
    rdfs:label "SelectControlById" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal:WithChildControlsEnum ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/with_child_controls> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/with_child_controls> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/with_ids> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/matching> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/with_child_controls> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/ControlMatching> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/matching> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/with_ids> ] ;
    skos:definition "Select a control or controls from an imported control set." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/controls> a owl:ObjectProperty ;
    rdfs:label "controls" ;
    rdfs:range <https://w3id.org/lmodel/oscal_catalog/Control> ;
    skos:definition "A collection of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/date> a owl:DatatypeProperty ;
    rdfs:label "date" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date and time when the action occurred." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/depends_on> a owl:DatatypeProperty ;
    rdfs:label "depends-on" ;
    rdfs:range xsd:string ;
    skos:definition "(deprecated) Another parameter invoking this one. This construct has been deprecated and should not be used." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/exclude_controls> a owl:DatatypeProperty ;
    rdfs:label "exclude-controls" ;
    skos:definition "Control-selection entries to exclude in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/include_controls> a owl:DatatypeProperty ;
    rdfs:label "include-controls" ;
    skos:definition "Control-selection entries to include in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/label> a owl:DatatypeProperty ;
    rdfs:label "label" ;
    rdfs:range xsd:string ;
    skos:definition "A short, placeholder name for the parameter, which can be used as a substitute for a value if no value is assigned." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/last_modified> a owl:DatatypeProperty ;
    rdfs:label "last-modified" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date and time the document was last modified." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/oscal_version> a owl:DatatypeProperty ;
    rdfs:label "oscal-version" ;
    rdfs:range xsd:string ;
    skos:definition "The OSCAL model version the document was authored against and will conform to as valid." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/param_id> a owl:DatatypeProperty ;
    rdfs:label "param-id" ;
    rdfs:range xsd:string ;
    skos:definition "The identifier for the parameter being set or referenced." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/published> a owl:DatatypeProperty ;
    rdfs:label "published" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date and time the document was last made available." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/scheme> a owl:DatatypeProperty ;
    rdfs:label "scheme" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Qualifies the kind of identifier using a URI." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/statement_id> a owl:DatatypeProperty ;
    rdfs:label "statement-id" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to a control statement identifier." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/text> a owl:DatatypeProperty ;
    rdfs:label "text" ;
    rdfs:range xsd:string ;
    skos:definition "A textual label to associate with the containing object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/usage> a owl:DatatypeProperty ;
    rdfs:label "usage" ;
    rdfs:range xsd:string ;
    skos:definition "Describes the purpose and use of a parameter." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_catalog/version> a owl:DatatypeProperty ;
    rdfs:label "version" ;
    rdfs:range xsd:string ;
    skos:definition "Used to distinguish a specific revision of an OSCAL document from other previous and future versions." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

<https://w3id.org/lmodel/oscal_mapping/category> a owl:DatatypeProperty ;
    rdfs:label "category" ;
    rdfs:range xsd:string ;
    skos:definition "Confidence category label or qualifier category value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_mapping/mapping_description> a owl:DatatypeProperty ;
    rdfs:label "mapping-description" ;
    rdfs:range xsd:string ;
    skos:definition "Description of the context and intended use of the mapping." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_mapping> .

<https://w3id.org/lmodel/oscal_profile/by_id> a owl:DatatypeProperty ;
    rdfs:label "by-id" ;
    rdfs:range xsd:string ;
    skos:definition "Identify or target items by their id value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_profile> .

<https://w3id.org/lmodel/oscal_ssp/ImpactLevel> a owl:Class ;
    rdfs:label "ImpactLevel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/adjustment_justification> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/base> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:Fips199ImpactLevelEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/selected> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/adjustment_justification> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/oscal_catalog/Link> ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/adjustment_justification> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( [ a rdfs:Datatype ;
                                owl:unionOf ( oscal:Fips199ImpactLevelEnum xsd:string ) ] xsd:string ) ] ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/base> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_ssp/selected> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
