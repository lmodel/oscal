            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/InformationType> .

<https://w3id.org/lmodel/oscal_ssp/InformationTypeCategorization> a sh:NodeShape ;
    rdfs:comment "A set of information type identifiers qualified by the given identification system used." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An identifier qualified by the given identification system used, such as NIST SP 800-60." ;
            sh:nodeKind sh:Literal ;
