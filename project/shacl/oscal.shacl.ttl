            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/type> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/SubjectReference> .

<https://w3id.org/lmodel/oscal_assessment_plan/SystemUser> a sh:NodeShape ;
