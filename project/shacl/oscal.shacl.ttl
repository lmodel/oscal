<https://w3id.org/lmodel/oscal_ssp/InformationType> a sh:NodeShape ;
    rdfs:comment "Contains details about one information type that is stored, processed, or transmitted by the system, such as privacy information, and its impact level." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_ssp/InformationTypeCategorization> ;
            sh:description "A set of information type identifiers qualified by the given identification system used." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/categorizations> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
            sh:description "The expected level of impact resulting from the disruption of access to or use of the described information or the information system." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/availability_impact> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
            sh:description "The expected level of impact resulting from the unauthorized modification of the described information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/integrity_impact> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> ;
            sh:description "The expected level of impact resulting from the unauthorized disclosure of the described information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/confidentiality_impact> ],
        [ sh:datatype xsd:string ;
