<https://w3id.org/lmodel/oscal_catalog/Control> a sh:NodeShape ;
    rdfs:comment "A structured object representing a requirement or guideline, which when implemented will reduce an aspect of risk related to an information system and its information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Part> ;
            sh:description "A collection of parts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/parts> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the control, which may be used by a tool for display and navigation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Parameter> ;
            sh:description "Parameters providing a mechanism for the dynamic assignment of value(s) in a control." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/params> ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies a control such that it can be referenced in the defining catalog and other OSCAL instances (e.g., profiles)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/id> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Control> ;
            sh:description "A collection of controls." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/controls> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/Control> .

<https://w3id.org/lmodel/oscal_mapping/ConfidenceScore> a sh:NodeShape ;
    rdfs:comment "Confidence represented as a category and/or percentage value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "A decimal percentage value in the range 0 to 1." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_mapping/percentage> ],
        [ sh:description "Confidence category label or qualifier category value." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "unspecified" "high" "medium" "low" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_mapping/category> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_mapping/ConfidenceScore> .

<https://w3id.org/lmodel/oscal_mapping/Coverage> a sh:NodeShape ;
    rdfs:comment "A percentage representing target coverage by source mappings." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "Percentage coverage of targets by sources." ;
            sh:maxCount 1 ;
            sh:maxInclusive 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_mapping/target_coverage> ],
        [ sh:description "Method used to determine the coverage value. Recommended values are in CoverageGenerationMethodEnum; other values are permitted." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "arbitrary" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_mapping/generation_method> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_mapping/Coverage> .

<https://w3id.org/lmodel/oscal_ssp/Diagram> a sh:NodeShape ;
    rdfs:comment "A graphic that provides a visual representation the system, or some aspect of it." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspDiagramLink> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "A brief caption to annotate the diagram." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/caption> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/Diagram> .

<https://w3id.org/lmodel/oscal_ssp/ImpactLevel> a sh:NodeShape ;
    rdfs:comment "The expected level of impact resulting from the described information's confidentiality, integrity, or availability affect." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:description "The prescribed base (Confidentiality, Integrity, or Availability) security impact level." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "fips-199-low" "fips-199-moderate" "fips-199-high" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/base> ],
        [ sh:datatype xsd:string ;
            sh:description "If the selected security level is different from the base security level, this contains the justification for the change." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/adjustment_justification> ],
        [ sh:description "The selected (Confidentiality, Integrity, or Availability) security impact level." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "fips-199-low" "fips-199-moderate" "fips-199-high" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/selected> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/ImpactLevel> .

<https://w3id.org/lmodel/oscal_ssp/SspControlOriginationProp> a sh:NodeShape ;
    rdfs:comment "SSP-scoped property used in implemented requirement and by-component contexts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:in ( "control-origination" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:in ( "organization" "system-specific" "customer-configured" "customer-provided" "inherited" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspControlOriginationProp> .

<https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonProperty> a sh:NodeShape ;
    rdfs:comment "Implementation-common scoped OSCAL property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "yes" "no" ) ] [ sh:in ( "operating-system" "database" "web-server" "dns-server" "email-server" "directory-server" "pbx" "firewall" "router" "switch" "storage-array" "appliance" ) ] [ sh:in ( "internal" "external" ) ] [ sh:in ( "local" "remote" ) ] [ sh:in ( "incoming" "outgoing" ) ] [ sh:in ( "internal" "external" "general-public" ) ] [ sh:in ( "privileged" "non-privileged" "no-logical-access" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:in ( "implementation-point" "leveraged-authorization-uuid" "inherited-uuid" "asset-type" "asset-id" "asset-tag" "public" "virtual" "vlan-id" "network-id" "label" "sort-id" "baseline-configuration-name" "allows-authenticated-scan" "function" "hardware-model" "model" "os-name" "os-version" "software-name" "software-version" "software-patch-level" "version" "patch-level" "release-date" "validation-type" "validation-reference" "vendor-name" "software-identifier" "isa-title" "isa-date" "isa-remote-system-name" "ipv4-address" "ipv6-address" "direction" "uri" "fqdn" "serial-number" "netbios-name" "mac-address" "physical-location" "is-scanned" "type" "privilege-level" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonProperty> .

