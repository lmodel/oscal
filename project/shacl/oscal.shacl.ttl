@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentMethod> a sh:NodeShape ;
    rdfs:comment "A local definition of a control objective." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPart> ;
            sh:description "An assessment part." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/part> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentMethod> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlanDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Assessment Plan document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlan> ;
            sh:description "The root assessment plan object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/assessment_plan> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlanDocument> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectPlaceholder> a sh:NodeShape ;
    rdfs:comment "Used when the assessment subjects will be determined as part of one or more other assessment activities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectSource> ;
            sh:description "Source references or source-participation entries in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/sources> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectPlaceholder> .

<https://w3id.org/lmodel/oscal_assessment_results/AssessmentResultsDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Assessment Results document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_results/AssessmentResults> ;
            sh:description "The root assessment results object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_results/assessment_results> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_results/AssessmentResultsDocument> .

<https://w3id.org/lmodel/oscal_catalog/CatalogDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Catalog document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Catalog> ;
            sh:description "Root catalog document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/catalog> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/CatalogDocument> .

<https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> a sh:NodeShape ;
    rdfs:comment "Mixin providing the props and links slots that are common to many OSCAL objects." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/HasPropsAndLinks> .

<https://w3id.org/lmodel/oscal_catalog/HasResponsibleParties> a sh:NodeShape ;
    rdfs:comment "Mixin providing the responsible-parties slot for objects that carry party assignments." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/ResponsibleParty> ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/responsible_parties> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/HasResponsibleParties> .

<https://w3id.org/lmodel/oscal_catalog/HasResponsibleRoles> a sh:NodeShape ;
    rdfs:comment "Mixin providing the responsible-roles slot for objects that carry role assignments." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/ResponsibleRole> ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/HasResponsibleRoles> .

<https://w3id.org/lmodel/oscal_catalog/OscalCommon> a sh:NodeShape ;
    rdfs:comment "Mixin providing props, links, and remarks slots common to most OSCAL objects. Extends HasPropsAndLinks." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/OscalCommon> .

<https://w3id.org/lmodel/oscal_catalog/OscalDocument> a sh:NodeShape ;
    rdfs:comment "A root wrapper for an OSCAL document, which may be of any OSCAL document type (e.g. Catalog, Profile, Assessment Plan, SSP)." ;
    sh:closed true ;
    sh:ignoredProperties ( <https://w3id.org/lmodel/oscal_poam/plan_of_action_and_milestones> <https://w3id.org/lmodel/oscal_assessment_plan/assessment_plan> <https://w3id.org/lmodel/oscal_ssp/system_security_plan> rdf:type <https://w3id.org/lmodel/oscal_assessment_results/assessment_results> <https://w3id.org/lmodel/oscal_profile/profile> <https://w3id.org/lmodel/oscal_component/component_definition> <https://w3id.org/lmodel/oscal_mapping/mapping_collection> <https://w3id.org/lmodel/oscal_catalog/catalog> ) ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/OscalDocument> .

<https://w3id.org/lmodel/oscal_catalog/PartyExternalId> a sh:NodeShape ;
    rdfs:comment "An identifier for a person or organization using a designated scheme, e.g. an Open Researcher and Contributor ID (ORCID)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Indicates the type of external identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "http://orcid.org/" ) ] [ sh:datatype xsd:anyURI ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/scheme> ],
        [ sh:datatype xsd:string ;
            sh:description "A unique human-oriented identifier within a particular context." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/id> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/PartyExternalId> .

<https://w3id.org/lmodel/oscal_component/ComponentDefinitionDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Component Definition document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_component/ComponentDefinition> ;
            sh:description "The root component-definition object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_component/component_definition> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_component/ComponentDefinitionDocument> .

<https://w3id.org/lmodel/oscal_mapping/MappingCollectionDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Mapping Collection document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_mapping/MappingCollection> ;
            sh:description "The root mapping collection object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_mapping/mapping_collection> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_mapping/MappingCollectionDocument> .

<https://w3id.org/lmodel/oscal_poam/PoamDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Plan of Action and Milestones document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_poam/PlanOfActionAndMilestones> ;
            sh:description "The root plan of action and milestones object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_poam/plan_of_action_and_milestones> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_poam/PoamDocument> .

<https://w3id.org/lmodel/oscal_profile/ProfileDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Profile document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_profile/Profile> ;
            sh:description "The root profile object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/profile> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/ProfileDocument> .

<https://w3id.org/lmodel/oscal_ssp/SspDocument> a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL System Security Plan document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_ssp/SystemSecurityPlan> ;
            sh:description "A system security plan, such as those described in NIST SP 800-18." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_security_plan> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspDocument> .

<https://w3id.org/lmodel/oscal_ssp/SspSystemCharacteristicsProp> a sh:NodeShape ;
    rdfs:comment "SSP-scoped property used in system characteristics." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "1" "2" "3" ) ] [ sh:in ( "public-cloud" "private-cloud" "community-cloud" "hybrid-cloud" "government-only-cloud" "other" ) ] [ sh:in ( "saas" "paas" "iaas" "other" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:in ( "identity-assurance-level" "authenticator-assurance-level" "federation-assurance-level" "cloud-deployment-model" "cloud-service-model" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspSystemCharacteristicsProp> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlan> a sh:NodeShape ;
    rdfs:comment "An assessment plan, such as those provided by a FedRAMP assessor." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ImportSSP> ;
            sh:description "Used to import information about the system from an SSP." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/import_ssp> ],
        [ sh:datatype xsd:string ;
            sh:description "Assessment Plan Universally Unique Identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/BackMatter> ;
            sh:description "A collection of resources that may be referenced from within the OSCAL document instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/back_matter> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/Task> ;
            sh:description "A collection of tasks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/tasks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/TermsAndConditions> ;
            sh:description "Terms and conditions under which an assessment can be performed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/terms_and_conditions> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Metadata> ;
            sh:description "Provides information about the containing document, and defines concepts shared across the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/metadata> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/LocalDefinitions> ;
            sh:description "Used to define data objects that do not appear in the referenced SSP." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/local_definitions> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ReviewedControls> ;
            sh:description "Identifies the controls being assessed and their control objectives." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/reviewed_controls> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentAssets> ;
            sh:description "Identifies the assets used to perform this assessment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/assessment_assets> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubject> ;
            sh:description "Identifies system elements being assessed." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/assessment_subjects> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlan> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlatform> a sh:NodeShape ;
    rdfs:comment "Used to represent the toolset used to perform aspects of the assessment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/UsesComponent> ;
            sh:description "The set of components used by the assessment platform." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/uses_components> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPlatform> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectSource> a sh:NodeShape ;
    rdfs:comment "Assessment subjects will be identified while conducting the referenced activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A UUID reference to a task." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/task_uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectSource> .

<https://w3id.org/lmodel/oscal_assessment_plan/AssociatedActivity> a sh:NodeShape ;
