            sh:description "The task is intended to occur on the specified date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/on_date> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/EventTiming> .

<https://w3id.org/lmodel/oscal_assessment_plan/Facet> a sh:NodeShape ;
    rdfs:comment "An individual characteristic that is part of a larger set produced by the same actor." ;
