            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SystemStatus> .

<https://w3id.org/lmodel/oscal_assessment_plan/Activity> a sh:NodeShape ;
    rdfs:comment "Identifies an assessment or related process that can be performed. In the assessment plan, this is an intended activity." ;
