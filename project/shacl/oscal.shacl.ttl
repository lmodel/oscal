<https://w3id.org/lmodel/oscal_catalog/Action> a sh:NodeShape ;
    rdfs:comment "An action applied by a role within a given party to the content." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:description "Specifies the action type system used." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "http://csrc.nist.gov/ns/oscal" ) ] [ sh:datatype xsd:anyURI ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/system> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time when the action occurred." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/date> ;
            sh:pattern "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$" ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier that can be used to reference this defined action elsewhere in an OSCAL document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "The type of action documented by the assembly, such as an approval." ;
