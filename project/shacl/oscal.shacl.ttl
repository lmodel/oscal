    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspStatement> .

<https://w3id.org/lmodel/oscal_ssp/SspSystemCharacteristicsResponsibleParty> a sh:NodeShape ;
    rdfs:comment "SSP-scoped responsible party for system characteristics." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/party_uuids> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:description "A reference to a role performed by a party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "authorizing-official" "authorizing-official-poc" "system-owner" "system-poc-management" "system-poc-technical" "system-poc-other" "information-system-security-officer" "privacy-poc" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/role_id> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspSystemCharacteristicsResponsibleParty> .

<https://w3id.org/lmodel/oscal_ssp/SspSystemComponent> a sh:NodeShape ;
    rdfs:comment "SSP-scoped system component with allows-authenticated-scan property typing." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:datatype xsd:string ;
            sh:description "A summary of the technological or business purpose of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/purpose> ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "this-system" "system" "interconnection" "software" "hardware" "service" "policy" "physical" "process-procedure" "plan" "guidance" "standard" "validation" "network" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStatus> ;
            sh:description "Status indicator used by the containing OSCAL context. Allowed values are constrained by class-level slot_usage." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/status> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspAllowsAuthenticatedScanProp> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonLink> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/Protocol> ;
            sh:description "Information about the protocol used to provide a service." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/protocols> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationResponsibleRole> ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/responsible_roles> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspSystemComponent> .

<https://w3id.org/lmodel/oscal_ssp/SspSystemInformationLink> a sh:NodeShape ;
    rdfs:comment "SSP-scoped link used in system information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Describes the type of relationship provided by the link's hypertext reference. This can be an indicator of the link's purpose." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "privacy-impact-assessment" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/rel> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label to associate with the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/text> ],
        [ sh:datatype xsd:string ;
            sh:description "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/resource_fragment> ],
        [ sh:datatype xsd:string ;
            sh:description "A label that indicates the nature of a resource, as a data serialization or format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/media_type> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/href> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspSystemInformationLink> .

<https://w3id.org/lmodel/oscal_ssp/SspSystemInformationProp> a sh:NodeShape ;
    rdfs:comment "SSP-scoped property used in system information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:in ( "yes" "no" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:in ( "privacy-designation" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspSystemInformationProp> .

<https://w3id.org/lmodel/oscal_ssp/SystemCharacteristics> a sh:NodeShape ;
    rdfs:comment "Contains the characteristics of the system, such as its name, purpose, and security impact level." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/SystemId> ;
            sh:description "Unique identifiers for the system." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_ids> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/NetworkArchitecture> ;
            sh:description "A description of the system's network architecture, optionally supplemented with diagrams that illustrate the network architecture." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/network_architecture> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
