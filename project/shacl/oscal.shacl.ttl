            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/Facet> .

<https://w3id.org/lmodel/oscal_assessment_plan/FindingTarget> a sh:NodeShape ;
    rdfs:comment "Captures an assessor's conclusions regarding the degree to which an objective is satisfied." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "statement-id" "objective-id" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/type> ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies the specific target qualified by the type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/target_id> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationStatus> ;
            sh:description "Identifies the implementation status of the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/implementation_status> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatus> ;
            sh:description "Status indicator used by the containing OSCAL context. Allowed values are constrained by class-level slot_usage." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/status> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/FindingTarget> .

<https://w3id.org/lmodel/oscal_assessment_plan/IdentifiedSubject> a sh:NodeShape ;
    rdfs:comment "Used to detail assessment subjects that were identified by this task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A reference to an assessment subject placeholder defined in the assessment plan." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/subject_placeholder_uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubject> ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/subjects> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/IdentifiedSubject> .

<https://w3id.org/lmodel/oscal_assessment_plan/LocalDefinitions> a sh:NodeShape ;
    rdfs:comment "Used to define data objects that are used in the assessment plan, that do not appear in the referenced SSP." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/LocalObjective> ;
            sh:description "A collection of locally-defined control objectives." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/objectives_and_methods> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/SystemUser> ;
            sh:description "A collection of system users." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/users> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/Activity> ;
            sh:description "A collection of activities." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/activities> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/InventoryItem> ;
            sh:description "A collection of inventory items." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/inventory_items> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/SystemComponent> ;
            sh:description "A collection of system components." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/components> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/LocalDefinitions> .

<https://w3id.org/lmodel/oscal_assessment_plan/MitigatingFactor> a sh:NodeShape ;
    rdfs:comment "Describes an existing mitigating factor that may affect the overall determination of the risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with cross-instance scope that can be used to reference this implementation statement elsewhere in this or other OSCAL instances." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/implementation_uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/SubjectReference> ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/subjects> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/MitigatingFactor> .

<https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatus> a sh:NodeShape ;
    rdfs:comment "A determination of if the objective is satisfied or not within a given system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "An indication as to whether the objective is satisfied or not." ;
            sh:in ( "satisfied" "not-satisfied" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/state> ],
        [ sh:description "The reason the objective was given its status. Recommended values are in ObjectiveStatusReasonEnum; other values are permitted (OSCAL allow-other=\"yes\")." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "pass" "fail" "other" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
