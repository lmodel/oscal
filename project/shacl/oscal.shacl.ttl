            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/remediations> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/Risk> .

