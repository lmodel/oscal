    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/ReviewedControls> ;
            sh:description "A reference to reviewed controls for this activity or step." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/related_controls> ],
        [ sh:datatype xsd:string ;
