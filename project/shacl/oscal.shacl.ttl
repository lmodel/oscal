                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/InformationTypeCategorization> .

