    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/Part> .

<https://w3id.org/lmodel/oscal_catalog/SelectControlById> a sh:NodeShape ;
    rdfs:comment "Select a control or controls from an imported control set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "When a control is included, whether its child (dependent) controls are also included." ;
            sh:in ( "yes" "no" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/with_child_controls> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/ControlMatching> ;
            sh:description "Selecting a set of controls by matching their IDs with a wildcard pattern." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/matching> ],
        [ sh:datatype xsd:string ;
            sh:description "Selecting a control by its ID given as a literal." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/with_ids> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/SelectControlById> .

<https://w3id.org/lmodel/oscal_ssp/SspByComponentResponsibleRole> a sh:NodeShape ;
    rdfs:comment "SSP-scoped responsible role used by by-component contexts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/party_uuids> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:description "A human-oriented identifier reference to a role performed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "asset-owner" "asset-administrator" "security-operations" "network-operations" "incident-response" "help-desk" "configuration-management" "maintainer" "provider" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/role_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SspByComponentResponsibleRole> .

<https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonLink> a sh:NodeShape ;
    rdfs:comment "Implementation-common scoped OSCAL link." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/resource_fragment> ],
        [ sh:datatype xsd:string ;
            sh:description "A label that indicates the nature of a resource, as a data serialization or format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/media_type> ],
        [ sh:description "Describes the type of relationship provided by the link's hypertext reference. This can be an indicator of the link's purpose." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "depends-on" "validation" "proof-of-compliance" "baseline-template" "uses-service" "system-security-plan" "uses-network" "imported-from" "validation-details" "provided-by" "used-by" "isa-agreement" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/rel> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label to associate with the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/text> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/href> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/ImplementationCommonLink> .

<https://w3id.org/lmodel/oscal_assessment_plan/Origin> a sh:NodeShape ;
    rdfs:comment "Identifies the source of the finding, such as a tool, interviewed person, or activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/RelatedTask> ;
            sh:description "Identifies tasks for which the containing object is a consequence." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/related_tasks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/OriginActor> ;
            sh:description "The actor that produces an observation, a finding, or a risk." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/actors> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_assessment_plan/Origin> .

<https://w3id.org/lmodel/oscal_catalog/ResponsibleParty> a sh:NodeShape ;
    rdfs:comment "A reference to a set of persons and/or organizations that have responsibility for performing the referenced role in the context of the containing object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/party_uuids> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:description "A reference to a role performed by a party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:in ( "creator" "prepared-by" "prepared-for" "content-approver" "contact" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/role_id> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/ResponsibleParty> .

<https://w3id.org/lmodel/oscal_catalog/BackMatter> a sh:NodeShape ;
    rdfs:comment "A collection of resources that may be referenced from within the OSCAL document instance." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Resource> ;
            sh:description "A resource associated with content in the containing document instance. A resource may be directly included in the document using base64 encoding or may point to one or more equivalent internet resources." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/resources> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/BackMatter> .

<https://w3id.org/lmodel/oscal_catalog/Metadata> a sh:NodeShape ;
    rdfs:comment "Provides information about the containing document, and defines concepts shared across the document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Revision> ;
            sh:description "An entry in a sequential list of revisions to the containing document, expected to be in reverse chronological order (i.e. latest first)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/revisions> ],
        [ sh:datatype xsd:string ;
            sh:description "The OSCAL model version the document was authored against." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/oscal_version> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Party> ;
            sh:description "An organization or person, which may be associated with roles or other concepts within the current or linked OSCAL document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/parties> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/MetadataProperty> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/DocumentId> ;
            sh:description "Document identifiers qualified by an identifier scheme." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/document_ids> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Location> ;
            sh:description "A physical point of presence, which may be associated with people, organizations, or other concepts within the current or linked OSCAL document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/locations> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Action> ;
            sh:description "An action applied by a role within a given party to the content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/actions> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Role> ;
            sh:description "Defines a function, which might be assigned to a party in a specific situation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/roles> ],
        [ sh:datatype xsd:string ;
            sh:description "Used to distinguish a specific revision of an OSCAL document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/version> ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/title> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time the document was last made available." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/published> ;
            sh:pattern "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/ResponsibleParty> ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/responsible_parties> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time the document was last stored for later retrieval." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/last_modified> ;
            sh:pattern "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?(Z|[+-]([01][0-9]|2[0-3]):[0-5][0-9])$" ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/Metadata> .

<https://w3id.org/lmodel/oscal_catalog/ResponsibleRole> a sh:NodeShape ;
    rdfs:comment "A reference to a role with responsibility for performing a function relative to the containing object, optionally associated with a set of persons and/or organizations that perform that role." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/party_uuids> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-oriented identifier reference to a role performed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/role_id> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/ResponsibleRole> .

<https://w3id.org/lmodel/oscal_catalog/Property> a sh:NodeShape ;
    rdfs:comment "An attribute, characteristic, or quality of the containing object expressed as a namespace qualified name/value pair." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/uuid> ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/Property> .

<https://w3id.org/lmodel/oscal_catalog/Link> a sh:NodeShape ;
    rdfs:comment "A reference to a local or remote resource, that has a specific relation to the containing object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ sh:description "Describes the type of relationship provided by the link's hypertext reference. This can be an indicator of the link's purpose." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:in ( "canonical" "alternate" "latest-version" "predecessor-version" "successor-version" "version-history" "reference" "source-profile" "source-profile-uuid" ) ] [ sh:datatype xsd:string ;
                        sh:nodeKind sh:Literal ] ) ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/rel> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label to associate with the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/text> ],
        [ sh:datatype xsd:string ;
            sh:description "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/resource_fragment> ],
        [ sh:datatype xsd:string ;
            sh:description "A label that indicates the nature of a resource, as a data serialization or format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/media_type> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_catalog/Link> .

