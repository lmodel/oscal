            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspSystemComponent> ;
            sh:description "A collection of system components." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/components> ],
        [ sh:class <https://w3id.org/lmodel/oscal_assessment_plan/SystemUser> ;
            sh:description "A collection of system users." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/users> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/Link> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspInventoryItem> ;
            sh:description "A collection of inventory items." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_assessment_plan/inventory_items> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SystemImplementation> .

<https://w3id.org/lmodel/oscal_ssp/SystemInformation> a sh:NodeShape ;
    rdfs:comment "Contains details about all information types that are stored, processed, or transmitted by the system, such as privacy information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspSystemInformationProp> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/InformationType> ;
            sh:description "Contains details about one information type that is stored, processed, or transmitted by the system." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/information_types> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspSystemInformationLink> ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/links> ] ;
