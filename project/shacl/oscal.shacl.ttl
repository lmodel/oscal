            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/alters> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/ProfileModify> .

<https://w3id.org/lmodel/oscal_profile/Removal> a sh:NodeShape ;
    rdfs:comment "Specifies objects to be removed from a control based on aspects of the object that must all match." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Identify items to remove by their class label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/by_class> ],
        [ sh:datatype xsd:string ;
            sh:description "Identify or target items by their id value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/by_id> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Identify items to remove by the item's namespace." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/by_ns> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:datatype xsd:string ;
            sh:description "Identify items to remove by their assigned name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/by_name> ],
        [ sh:description "Identify items to remove by the item's information object type name." ;
            sh:in ( "param" "prop" "link" "part" "mapping" "map" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/by_item_name> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/Removal> .

<https://w3id.org/lmodel/oscal_ssp/AuthorizationBoundary> a sh:NodeShape ;
    rdfs:comment "A description of this system's authorization boundary, optionally supplemented with diagrams that illustrate the authorization boundary." ;
    sh:closed true ;
