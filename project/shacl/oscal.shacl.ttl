<https://w3id.org/lmodel/oscal_ssp/SystemSecurityPlan> a sh:NodeShape ;
    rdfs:comment "A system security plan, such as those described in NIST SP 800-18." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspControlImplementation> ;
            sh:description "Describes how the system satisfies a set of controls." ;
