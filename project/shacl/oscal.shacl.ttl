            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_name_short> ],
        [ sh:datatype xsd:string ;
            sh:description "The overall information system sensitivity categorization, such as defined by FIPS-199." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/security_sensitivity_level> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SspSystemCharacteristicsResponsibleParty> ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/responsible_parties> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SystemInformation> ;
            sh:description "Contains details about all information types that are stored, processed, or transmitted by the system." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_information> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SystemStatus> ;
            sh:description "Describes the operational status of the system." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_status> ],
        [ sh:datatype xsd:string ;
            sh:description "The full name of the system." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/system_name> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/description> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/AuthorizationBoundary> ;
            sh:description "A description of this system's authorization boundary, optionally supplemented with diagrams that illustrate the authorization boundary." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/authorization_boundary> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/DataFlow> ;
            sh:description "A description of the logical flow of information within the system and across its boundaries, optionally supplemented with diagrams." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/data_flow> ],
        [ sh:datatype xsd:string ;
            sh:description "The date the system received its authorization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/date_authorized> ],
        [ sh:class <https://w3id.org/lmodel/oscal_ssp/SecurityImpactLevel> ;
            sh:description "The overall level of expected impact resulting from unauthorized disclosure, modification, or loss of access to information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/oscal_ssp/security_impact_level> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_ssp/SystemCharacteristics> .

<https://w3id.org/lmodel/oscal_ssp/SystemImplementation> a sh:NodeShape ;
    rdfs:comment "Provides information as to how the system is implemented." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_ssp/LeveragedAuthorization> ;
