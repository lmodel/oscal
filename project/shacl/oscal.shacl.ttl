<https://w3id.org/lmodel/oscal_assessment_plan/RiskLogEntry> a sh:NodeShape ;
    rdfs:comment "Identifies an individual risk response that occurred as part of managing an identified risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_catalog/Property> ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/props> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The start date/time." ;
