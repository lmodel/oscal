            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/ns> ],
        [ sh:datatype xsd:string ;
            sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/value> ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/group> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/remarks> ],
        [ sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:in ( "label" "sort-id" "alt-identifier" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/name> ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/_class> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/ProfileAlterationProperty> .

<https://w3id.org/lmodel/oscal_profile/ProfileImport> a sh:NodeShape ;
    rdfs:comment "Designates a referenced source catalog or profile that provides a source of control information for use in creating a new overlay or baseline." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/href> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/SelectControlById> ;
            sh:description "Control-selection entries to include in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/include_controls> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/SelectControlById> ;
            sh:description "Control-selection entries to exclude in the containing OSCAL context. The concrete entry class is selected by class-level slot_usage." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/exclude_controls> ],
        [ sh:class <https://w3id.org/lmodel/oscal_catalog/IncludeAll> ;
            sh:description "Include all selectable objects in the containing OSCAL selection context." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_catalog/include_all> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/ProfileImport> .

<https://w3id.org/lmodel/oscal_profile/ProfileMerge> a sh:NodeShape ;
    rdfs:comment "Provides structuring directives that instruct how controls are organized after profile resolution." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_profile/MergeFlat> ;
            sh:description "Directs that controls appear without any grouping structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/flat> ],
        [ sh:datatype xsd:boolean ;
            sh:description "When true, retain the original grouping structure as defined in the import source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/as_is> ],
        [ sh:class <https://w3id.org/lmodel/oscal_profile/MergeCustom> ;
            sh:description "Provides an alternate grouping structure that selected controls will be placed in." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/custom> ],
        [ sh:class <https://w3id.org/lmodel/oscal_profile/CombinationRule> ;
            sh:description "Defines how to resolve duplicate instances of the same control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/oscal_profile/combine> ] ;
    sh:targetClass <https://w3id.org/lmodel/oscal_profile/ProfileMerge> .

<https://w3id.org/lmodel/oscal_profile/ProfileModify> a sh:NodeShape ;
    rdfs:comment "Set parameters or amend controls in resolution." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/oscal_profile/ParameterSetting> ;
            sh:description "A parameter setting to be propagated to points of insertion." ;
